# This file configures the Python backfill (projects/backfill). The Cloudflare
# Worker's local dev config lives in projects/worker/.dev.vars instead
# (gitignored — copy projects/worker/.dev.vars.example; DEV_MODE=true there
# enables the dev-open API lane and the dev_link login flow).

# --- Generation providers (backfill, via genblaze) ---
OPENAI_API_KEY=
GEMINI_API_KEY=          # optional generation provider (Imagen via genblaze) — generation only, not embeddings
GMICLOUD_API_KEY=
DEFAULT_IMAGE_MODEL=gpt-image-1

# --- Backblaze B2 (image bytes + provenance manifests, written by the backfill) ---
B2_KEY_ID=
B2_APP_KEY=
B2_BUCKET=
B2_REGION=us-west-004
# Public file URL base for a public-read B2 bucket (required for the playground to render
# cached images). E.g. https://f004.backblazeb2.com/file/<bucket-name>
# Without this, image URLs from a private bucket will 403 in the browser.
# Future alternative: presigning (not yet implemented).
B2_PUBLIC_URL_BASE=

# --- Cloudflare (backfill worker; the request path lives in the Worker) ---
CF_ACCOUNT_ID=
CF_API_TOKEN=
D1_DATABASE_ID=
VECTORIZE_INDEX_NAME=wagmiphotos-bge

# --- BGE text embeddings ---
# The backfill loads BAAI/bge-base-en-v1.5 in-process (pinned in contract.json);
# no separate embedding service or tunnel to configure.
EMBEDDING_DIMS=768

# --- Similarity floor (BGE text-to-text scale (placeholders — live-tune against the seeded pool)) ---
FLOOR_SIM_MAX=0.90
FLOOR_SIM_MIN=0.72

# --- Auth (magic-link login — Worker-side; set in prod via `npx wrangler secret put`) ---
RESEND_API_KEY=          # in local dev the login link is echoed/logged only when DEV_MODE=true (projects/worker/.dev.vars)
EMAIL_FROM=login@wagmi.photos
