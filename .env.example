OPENAI_API_KEY=
GEMINI_API_KEY=
B2_KEY_ID=
B2_APP_KEY=
B2_BUCKET=
B2_REGION=us-west-004
# Public file URL base for a public-read B2 bucket (required for the playground to render
# cached images). E.g. https://f004.backblazeb2.com/file/<bucket-name>
# Without this, image URLs from a private bucket will 403 in the browser.
# Future alternative: presigning (not yet implemented).
B2_PUBLIC_URL_BASE=
DATABASE_URL=postgresql://localhost:5432/sharedcache
EMBEDDING_DIMS=768
DEFAULT_IMAGE_MODEL=gpt-image-1
API_KEY=
# --- Cloudflare (backfill worker; request path lives in the Worker) ---
CF_ACCOUNT_ID=
CF_API_TOKEN=
D1_DATABASE_ID=
VECTORIZE_INDEX_NAME=sharedcache-clip
# --- BGE text embeddings ---
# The backfill loads BAAI/bge-base-en-v1.5 in-process (see deploy/gmi); no
# separate embedding service or tunnel to configure.
# --- Similarity floor (CLIP cross-modal scale; tune against the seeded pool) ---
FLOOR_SIM_MAX=0.35
FLOOR_SIM_MIN=0.18
# --- Auth (magic-link login) ---
RESEND_API_KEY=          # unset locally → magic links log to console + return in the login response
EMAIL_FROM=login@wagmi.photos
