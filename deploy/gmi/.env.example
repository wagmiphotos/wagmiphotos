# Backfill worker env for the GMI box — copy to deploy/gmi/.env and fill the
# blanks. docker-compose loads this via env_file. NEVER commit the real .env.

# --- Cloudflare (REST access for D1 + Vectorize) ---
CF_ACCOUNT_ID=
# API token with D1:edit + Vectorize:edit scopes (create at dash.cloudflare.com
# → My Profile → API Tokens; do NOT use the Global API Key)
CF_API_TOKEN=
# from `npx wrangler d1 create wagmiphotos` (also in projects/worker/wrangler.toml)
D1_DATABASE_ID=

# --- Vectorize sharding (must match contract.json — parity-tested) ---
VECTORIZE_INDEX_PREFIX=wagmiphotos-bge-
VECTORIZE_SHARDS=3

# --- Generation provider ---
GMICLOUD_API_KEY=
# GMICloud image model — case-sensitive slug; must have a live serving worker
# on your account (submit a request and confirm it reaches status=success, not
# stuck 'queued'). gpt-image-2-generate and seedream-5.0-lite work; open models
# (Z-Image-Turbo, Qwen-Image-2512) are recognized but have no worker (queue forever).
DEFAULT_IMAGE_MODEL=gpt-image-2-generate
# Generation size, WxH. Model-dependent: gpt-image-2-generate accepts 1024x1024;
# seedream-5.0-lite rejects it and needs 2048x2048.
GENERATION_SIZE=1024x1024

# --- Hugging Face (PD12M seed source; needed only for seed_pd12m runs) ---
# Read token for the dataset repo (it is private): hf.co → Settings → Access Tokens
HF_TOKEN=

# --- Backblaze B2 (public-read bucket; base MUST equal the Worker's ASSET_BASE_URL) ---
B2_KEY_ID=
B2_APP_KEY=
B2_BUCKET=
B2_REGION=
B2_PUBLIC_URL_BASE=

# --- Similarity floors (keep in sync with Worker wrangler.toml [vars]) ---
FLOOR_SIM_MAX=0.87
FLOOR_SIM_MIN=0.75

# --- Optional spend guards (defaults shown; uncomment to override) ---
# WORKER_MAX_SPEND_USD=5.0            # per generate-pass cap
# WORKER_MAX_LIFETIME_SPEND_USD=      # durable cross-restart cap (D1 meta table)
# WORKER_BATCH_SIZE=5
# IMAGE_PRICE_USD=0.055  # assumed per-image price: spend-cap math + stored per-asset (price_usd).
#                        # gpt-image-2-generate @ 1024x1024 medium = $0.055; quality-dependent.
# GENERATION_MIN_REQUESTS=10  # demand gate: only build prompts requested >= N times (skip one-offs)
